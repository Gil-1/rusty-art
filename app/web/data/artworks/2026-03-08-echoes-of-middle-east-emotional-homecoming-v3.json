          "glsl": {
            "fragment": "precision highp float; varying vec2 vUv; uniform float uTime; uniform float uWarmGap; uniform float uShardBias; uniform float uGrain; float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453123);} float noise(vec2 p){vec2 i=floor(p); vec2 f=fract(p); vec2 u=f*f*(3.0-2.0*f); return mix(mix(hash(i),hash(i+vec2(1.0,0.0)),u.x),mix(hash(i+vec2(0.0,1.0)),hash(i+vec2(1.0,1.0)),u.x),u.y);} void main(){vec2 uv=vUv; vec3 bg=vec3(0.035,0.031,0.043); vec3 dark=vec3(0.090,0.075,0.102); vec3 ochre=vec3(0.824,0.690,0.310); vec3 bone=vec3(0.906,0.847,0.733); vec3 ember=vec3(0.498,0.133,0.122); float n=noise(uv*vec2(4.5,1.8)); float vertical=noise(vec2(uv.x*7.0, uv.y*0.9)); float gate=1.0-smoothstep(uWarmGap, uWarmGap+0.09, abs(uv.x-0.52 + (n-0.5)*0.09)); float torn=smoothstep(uShardBias-0.12,uShardBias+0.08, vertical + (1.0-uv.y)*0.11 + (n-0.5)*0.2); vec3 col=mix(bg, ochre, 0.62 + 0.18*(1.0-uv.y)); col=mix(col, bone, gate*0.42); col=mix(col, dark, torn*0.88); float emberLine=(smoothstep(0.0,0.18,gate)-smoothstep(0.18,0.34,gate))*0.32; col += ember*emberLine; col += (noise(uv*18.0)-0.5)*uGrain*0.08; gl_FragColor=vec4(col,0.98);}"
