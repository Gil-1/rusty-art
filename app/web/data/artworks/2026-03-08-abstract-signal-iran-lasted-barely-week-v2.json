          "glsl": {
            "fragment": "precision highp float; varying vec2 vUv; uniform float uTime; uniform float uFractureFreq; uniform float uStrataTilt; uniform float uGlowBias; uniform float uBanding; float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453123);} float noise(vec2 p){vec2 i=floor(p); vec2 f=fract(p); vec2 u=f*f*(3.0-2.0*f); return mix(mix(hash(i+vec2(0.0,0.0)),hash(i+vec2(1.0,0.0)),u.x),mix(hash(i+vec2(0.0,1.0)),hash(i+vec2(1.0,1.0)),u.x),u.y);} void main(){vec2 uv=vUv; uv.x += (uv.y-0.5)*uStrataTilt; float n=noise(uv*vec2(uFractureFreq,2.4)); float bands=abs(sin((uv.y+n*0.16)*uBanding)); float seam=smoothstep(0.47,0.505,n)-smoothstep(0.505,0.54,n); vec3 bg=vec3(0.06,0.05,0.04); vec3 primary=vec3(0.165,0.114,0.102); vec3 secondary=vec3(0.604,0.416,0.184); vec3 glow=vec3(0.776,0.290,0.165); vec3 col=mix(primary,secondary,bands*0.18 + pow(max(uv.y,0.0),1.7)*0.07); col=mix(bg,col,0.88); col += glow*seam*uGlowBias; float alpha=0.78 + seam*0.14; gl_FragColor=vec4(col,alpha);}"
